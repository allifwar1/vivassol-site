# ============================================================
# Variáveis de ambiente da Vivassol Site
# Copie este arquivo para ".env.local" e preencha os valores.
# NUNCA comite o .env.local (ele está no .gitignore).
# Na Vercel, estes valores vão em Settings > Environment Variables.
# ============================================================

# --- Integração com Vivassol Gerencial (Apps Script) ---
# URL do Web App publicado (termina em /exec)
GERENCIAL_API_URL=
# Token secreto da API (o MESMO de js/config.js e Code.gs do Gerencial)
# IMPORTANTE: vive só no servidor, NUNCA exposto ao navegador.
GERENCIAL_API_TOKEN=

# --- Mercado Pago (Fase 3) ---
MERCADOPAGO_ACCESS_TOKEN=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=

# --- Painel Admin (Fase 4) ---
ADMIN_PASSWORD=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- Cloudinary (upload de fotos - Fase 4) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
